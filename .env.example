# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXTAUTH_URL=https://your-app.vercel.app
NEXTAUTH_SECRET=change-this-to-a-long-random-string

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/lynq?retryWrites=true

# ─── Redis (optional — for rate limiting / caching) ──────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SOLO_PRICE_ID=price_...       # Solo plan — fixed monthly price
STRIPE_BUSINESS_PRICE_ID=price_...   # Business plan — per-user monthly price

# ─── AI (OpenRouter — NVIDIA Nemotron Nano 30B, free) ────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# ─── Google OAuth (Sign in with Google) ───────────────────────────────────────
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add Authorized redirect URIs:
#    - https://lynq.cards/api/auth/callback/google   (production)
#    - http://localhost:3000/api/auth/callback/google (local)
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ─── Microsoft / Outlook ─────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=...
MICROSOFT_CLIENT_SECRET=...

# ─── Odoo (OPTIONAL — leave blank if not using Odoo integration) ─────────────
# ODOO_URL=https://your-odoo.odoo.com
# ODOO_DATABASE=your_database
