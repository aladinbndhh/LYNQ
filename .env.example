# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXTAUTH_URL=https://your-app.vercel.app
NEXTAUTH_SECRET=change-this-to-a-long-random-string

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/lynq?retryWrites=true

# ─── Redis (optional — for rate limiting / caching) ──────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# ─── AI (Google Gemini) ───────────────────────────────────────────────────────
GOOGLE_AI_API_KEY=AIza...

# ─── Google OAuth (Sign in with Google + Calendar) ───────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ─── Microsoft / Outlook ─────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=...
MICROSOFT_CLIENT_SECRET=...

# ─── Odoo (OPTIONAL — leave blank if not using Odoo integration) ─────────────
# ODOO_URL=https://your-odoo.odoo.com
# ODOO_DATABASE=your_database
